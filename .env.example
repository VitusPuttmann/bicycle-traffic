# Docker Airflow Setup
AIRFLOW_UID=50000
AIRFLOW__CORE__FERNET_KEY=          # generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW__API__SECRET_KEY=           # generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
AIRFLOW__API_AUTH__JWT_SECRET=      # generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
AIRFLOW__CORE__SIMPLE_AUTH_MANAGER_USERS=admin:your-strong-password
_PIP_ADDITIONAL_REQUIREMENTS=-r /opt/airflow/requirements.txt
FERNET_KEY=your_generated_key_here  # generate with python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"